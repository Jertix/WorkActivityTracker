    // Dati di lookup caricati dal database
    private List<Cliente> clienti = new();
    private List<Ambiente> ambienti = new();
    private List<int> anniDisponibili = new();
    private string utenteConnesso = "Caricamento...";
    
    /// <summary>
    /// Clienti ordinati con "Sviluppo" come prima scelta
