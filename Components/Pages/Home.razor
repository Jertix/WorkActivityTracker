    #region Storico Versioni Editor (Undo/Redo)

    /// <summary>
    /// Carica lo storico Note (se non ancora caricato) e naviga alla versione precedente.
    /// Al primo Undo: salva il contenuto corrente e carica l'indice 0 (versione più recente).
    /// Agli Undo successivi: incrementa l'indice (versione più vecchia).
    /// </summary>
    private async Task NoteUndo()
    {
        if (!IsModifica) return;

        if (_noteHistory == null)
        {
            try { _noteContenutoSalvato = await JS.InvokeAsync<string>("noteEditorHelper.getHtml", noteEditorRef); }
            catch { _noteContenutoSalvato = AttivitaCorrente.Note; }

            _noteHistory = await EditorHistoryService.GetStoricoAsync(AttivitaCorrente.Id, "Note");
            _noteHistoryIndex = -1;
        }

        if (_noteHistory == null || !_noteHistory.Any()) return;

        _noteHistoryIndex++;
        if (_noteHistoryIndex >= _noteHistory.Count)
            _noteHistoryIndex = _noteHistory.Count - 1;

        await ImpostaContenutoNoteEditor(_noteHistory[_noteHistoryIndex].Contenuto ?? string.Empty);
    }

    /// <summary>
    /// Naviga alla versione successiva (più recente) dello storico Note.
    /// Se si torna all'indice -1 (prima dell'undo), ripristina il contenuto corrente.
    /// </summary>
    private async Task NoteRedo()
    {
        if (_noteHistory == null || !_noteHistory.Any()) return;

        _noteHistoryIndex--;
        if (_noteHistoryIndex < 0)
        {
            _noteHistoryIndex = -1;
            await ImpostaContenutoNoteEditor(_noteContenutoSalvato ?? string.Empty);
        }
        else
        {
            await ImpostaContenutoNoteEditor(_noteHistory[_noteHistoryIndex].Contenuto ?? string.Empty);
        }
    }

