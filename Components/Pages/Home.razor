                                   placeholder="Seleziona una cartella..." readonly />
                            @if (!string.IsNullOrEmpty(AttivitaCorrente.CartellaDocumentazione) && Directory.Exists(AttivitaCorrente.CartellaDocumentazione))
                            {
                                <button class="btn btn-success" type="button" @onclick="ApriCartella">
                                    📂 Apri cartella
                                </button>
                            }
                            @if (!string.IsNullOrEmpty(AttivitaCorrente.CartellaDocumentazione))
                            {
                                <button class="btn btn-outline-danger" type="button" @onclick="() => AttivitaCorrente.CartellaDocumentazione = null">
                                    ✕
                                </button>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(AttivitaCorrente.CartellaDocumentazione) && !Directory.Exists(AttivitaCorrente.CartellaDocumentazione))
                        {
                            <small class="text-danger">⚠️ La cartella non esiste</small>
                        }
