                        <label class="form-label">Numero del ticket</label>
                        <input type="text" class="form-control"
                               @bind="AttivitaCorrente.NumeroTicket"
                               placeholder="Es: 12345"
                               title="Inserire il numero del ticket, usare la virgola se sono più di uno" />
                    </div>
                }

