        changesetEditorNeedsUpdate = true;
    }

    /// <summary>
    /// Legge il testo grezzo (plain text) dal contenteditable editor JS e aggiorna il campo C#.
    /// Usato prima di AggiungiBloccoCongelato per confronti stringa senza HTML.
    /// </summary>
    private async Task SincronizzaTestoEditorAsync()
    {
        try
        {
            // Salva HTML (non plain text) per preservare la formattazione (bold, highlight, ecc.)
            var html = await JS.InvokeAsync<string>("changesetEditorHelper.getHtml", changesetEditorRef);
            AttivitaCorrente.ChangesetCoinvolti = string.IsNullOrWhiteSpace(html) ? null : html;
        }
        catch { /* Ignora errori JS */ }
    }

    /// <summary>
    /// Aggiunge un blocco congelato al testo dei changeset solo se la riga intestazione non è già presente.
    /// Formato aggiunto:
    ///   NomeCongelato (Versione):
    ///   Changeset XXX: [Testo del check-in]
    ///   (riga vuota)
    /// </summary>
    /// <summary>
    /// Formatta la versione del congelato aggiungendo la versione secondaria 4.1.X,
    /// dove X = patch - 50 (es: 3.2.60 → 3.2.60-4.1.10).
    /// Se la descrizione non ha formato X.Y.Z, la restituisce invariata.
    /// </summary>
    private static string FormattaVersioneCongelato(string? descrizione)
    {
        if (string.IsNullOrEmpty(descrizione)) return string.Empty;
        var parts = descrizione.Trim().Split('.');
        if (parts.Length == 3 && int.TryParse(parts[2], out int patch))
            return $"{descrizione}-4.1.{patch - 50}";
        return descrizione;
    }

    private void AggiungiBloccoCongelato(string rigaIntestazione)
    {
        // Il campo può contenere HTML: usa HtmlToPlainText per il confronto
        var testoCorrente = HtmlToPlainText(AttivitaCorrente.ChangesetCoinvolti);
        var testoCheckIn = AttivitaCorrente.TestoCheckIn ?? "";

        // Verifica se la riga intestazione è già presente (ignora spazi/CR extra)
        var linee = testoCorrente.Split('\n').Select(l => l.TrimEnd()).ToList();
        bool giaPresente = linee.Any(l => l.Equals(rigaIntestazione.TrimEnd(), StringComparison.OrdinalIgnoreCase));

        if (!giaPresente)
        {
            // Preserva l'HTML esistente e appende il nuovo blocco come HTML
            var heading = System.Net.WebUtility.HtmlEncode(rigaIntestazione);
            var checkIn = System.Net.WebUtility.HtmlEncode(testoCheckIn);
            var nuovoBlocco = $"<strong>{heading}</strong><br>Changeset XXX: {checkIn}";

            var htmlEsistente = AttivitaCorrente.ChangesetCoinvolti ?? "";
            if (!string.IsNullOrWhiteSpace(htmlEsistente))
            {
                // Rimuove eventuali <br> finali prima di appendere
                htmlEsistente = System.Text.RegularExpressions.Regex.Replace(
                    htmlEsistente.TrimEnd(), @"(<br\s*/?>\s*)+$", "",
                    System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                AttivitaCorrente.ChangesetCoinvolti = htmlEsistente + "<br><br>" + nuovoBlocco;
            }
            else
            {
                AttivitaCorrente.ChangesetCoinvolti = nuovoBlocco;
            }
        }
    }

