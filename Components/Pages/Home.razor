    /// <summary>
    /// Placeholder dinamico per il campo "Versione di sviluppo": mostra la versione calcolata
    /// come suggerimento, oppure un esempio statico se non ci sono congelati.
    /// </summary>
    private string VersioneSviluppoPlaceholder
    {
        get
        {
            var v = CalcolaVersioneSviluppoSuccessiva();
            return string.IsNullOrEmpty(v) ? "Es: 3.2.61" : v;
        }
    }

    /// <summary>
    /// Calcola la versione di sviluppo successiva basandosi sulla prima versione dei congelati.
    /// Es: se la prima versione è 3.2.60, restituisce 3.2.61
    /// </summary>
    private string CalcolaVersioneSviluppoSuccessiva()
    {
        try
        {
            // Prende il primo ambiente (che ha la versione più alta grazie all'ordinamento)
            var primoAmbiente = ambienti.FirstOrDefault();
            if (primoAmbiente == null || string.IsNullOrEmpty(primoAmbiente.Descrizione))
                return string.Empty;

            // La descrizione è nel formato "X.Y.Z" (solo numeri)
            var descrizione = primoAmbiente.Descrizione;
            var match = System.Text.RegularExpressions.Regex.Match(descrizione, @"(\d+)\.(\d+)\.(\d+)");
            
            if (match.Success)
            {
                var major = int.Parse(match.Groups[1].Value);
                var minor = int.Parse(match.Groups[2].Value);
                var patch = int.Parse(match.Groups[3].Value);
                
                // Incrementa il patch di 1
                return $"{major}.{minor}.{patch + 1}";
            }
        }
        catch
        {
            // In caso di errore, restituisce stringa vuota
        }
        
        return string.Empty;
    }

