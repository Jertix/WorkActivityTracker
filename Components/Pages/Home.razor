@if (mostraConfermaElimina && attivitaDaEliminare != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 2000;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">🗑️ Conferma Eliminazione</h5>
                </div>
                <div class="modal-body">
                    <p>Sei sicuro di voler eliminare questa attività?</p>
                    <table class="table table-sm table-borderless mb-0">
                        <tr>
                            <td class="fw-bold text-muted" style="width: 80px;">Data:</td>
                            <td>@attivitaDaEliminare.Data.ToString("dd/MM/yyyy")</td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-muted">Titolo:</td>
                            <td>@TruncateText(attivitaDaEliminare.Descrizione, 80)</td>
                        </tr>
                    </table>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="AnnullaElimina">❌ Annulla</button>
                    <button class="btn btn-danger" @onclick="ConfermaElimina">🗑️ Sì, elimina</button>
                </div>
            </div>
        </div>
    </div>
}

