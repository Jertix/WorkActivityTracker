                     AttivitaCorrente.TipoAttivita != TipiAttivita.Ferie)
                {
                    <div class="col-md-8">
                        <label class="form-label">URL Ticket / CR / Backlog, etc...</label>
                        <textarea class="form-control @(CampoHaTodo(AttivitaCorrente.UrlTicket) ? "campo-con-todo" : "")"
                                  @bind="AttivitaCorrente.UrlTicket" rows="2"
                                  placeholder="Inserisci URL, numeri CR, backlog item, etc..."></textarea>
                        @* Anteprima URL cliccabili: gli http(s):// vengono convertiti in link *@
                        @if (!string.IsNullOrWhiteSpace(AttivitaCorrente.UrlTicket) && ContienUrl(AttivitaCorrente.UrlTicket))
                        {
                            <div class="mt-1 small" style="line-height: 1.8;">
                                @foreach (var seg in ParseUrlSegmenti(AttivitaCorrente.UrlTicket))
                                {
                                    @if (seg.IsUrl)
                                    {
                                        var urlCapt = seg.Testo;
                                        <a href="#" @onclick="() => ApriUrl(urlCapt)" @onclick:preventDefault
                                           class="text-primary me-1" style="word-break: break-all; cursor: pointer;"
                                           title="Apri URL nel browser">@seg.Testo</a>
                                    }
                                    else
                                    {
                                        <span style="white-space: pre-wrap;">@seg.Testo</span>
                                    }
                                }
                            </div>
                        }
                    </div>
