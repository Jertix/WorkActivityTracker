                        <label class="form-label">Modifica riportata sui congelati:</label>
                        <div class="border rounded p-2" style="max-height: 180px; overflow-y: auto;">
                            <table class="table table-sm table-borderless mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 30px;"></th>
                                        <th>Nome</th>
                                        <th>Versione</th>
                                        <th style="width: 100px;">Data Cong.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @* ===== PRIMA RIGA: Sviluppo (virtuale, non nel DB) ===== *@
                                    <tr class="table-info">
                                        <td>
                                            <input class="form-check-input" type="checkbox"
                                                   id="amb_sviluppo"
                                                   checked="@isSviluppoSelezionato"
                                                   @onchange="e => ToggleSviluppo((bool)e.Value!)" />
                                        </td>
                                        <td>
                                            <label class="form-check-label fw-bold" for="amb_sviluppo">
                                                Sviluppo
                                            </label>
                                        </td>
                                        <td class="text-muted fw-bold">
                                            @AttivitaCorrente.Versione
                                        </td>
                                        <td class="text-muted">-</td>
                                    </tr>
                                    @* ===== Ambienti dal database ===== *@
                                    @foreach (var ambiente in ambienti)
                                    {
                                        <tr>
                                            <td>
                                                <input class="form-check-input" type="checkbox"
                                                       id="@($"amb_{ambiente.Id}")"
                                                       checked="@AttivitaCorrente.AmbientiSelezionatiIds.Contains(ambiente.Id)"
                                                       @onchange="e => ToggleAmbiente(ambiente.Id, (bool)e.Value!)" />
                                            </td>
                                            <td>
                                                <label class="form-check-label" for="@($"amb_{ambiente.Id}")">
                                                    @ambiente.Codice
                                                </label>
                                            </td>
                                            <td class="text-muted">
                                                @ambiente.Descrizione
                                            </td>
                                            <td class="text-muted small">
                                                @(ambiente.DataCongelamento?.ToString("dd/MM/yy") ?? "-")
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
