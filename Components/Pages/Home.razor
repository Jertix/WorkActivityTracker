    /// <summary>
    /// Aggiunge o rimuove un congelato dalla lista dei congelati selezionati.
    /// In caso di spunta: aggiunge il blocco solo se non già presente nel testo.
    /// In caso di dispunta: rimuove solo l'ID dalla lista (non modifica il testo manuale).
    /// </summary>
    private async Task ToggleAmbiente(int ambienteId, bool selezionato)
    {
        if (selezionato && !AttivitaCorrente.AmbientiSelezionatiIds.Contains(ambienteId))
        {
            AttivitaCorrente.AmbientiSelezionatiIds.Add(ambienteId);

            // Legge il testo corrente dall'editor JS prima di modificarlo
            await SincronizzaTestoEditorAsync();

            // Aggiunge il blocco solo se la riga intestazione non è già presente
            var ambiente = ambienti.FirstOrDefault(a => a.Id == ambienteId);
            if (ambiente != null)
            {
                AggiungiBloccoCongelato($"{ambiente.Codice} ({FormattaVersioneCongelato(ambiente.Descrizione)}):");
            }

            // Aggiorna il DOM dell'editor con il nuovo contenuto
            changesetEditorNeedsUpdate = true;
        }
        else if (!selezionato && AttivitaCorrente.AmbientiSelezionatiIds.Contains(ambienteId))
        {
            AttivitaCorrente.AmbientiSelezionatiIds.Remove(ambienteId);
            // Non modifica il testo: l'utente potrebbe aver editato manualmente
        }

        changesetEditorNeedsUpdate = true;
    }

