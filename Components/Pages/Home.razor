    /// <summary>
    /// Genera il testo plain di un'attività (senza HTML) per export TXT.
    /// </summary>
    private string GeneraTestoAttivitaPlain(WorkActivityDto att)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"📅 Data: {att.Data:dd/MM/yyyy}");
        if (!string.IsNullOrEmpty(att.TipoAttivita) && att.TipoAttivita != TipiAttivita.Lavoro)
            sb.AppendLine($"🏷️ Tipo: {att.TipoAttivita}");
        sb.AppendLine($"📝 Descrizione: {att.Descrizione ?? "-"}");
        if (!string.IsNullOrEmpty(att.UrlTicket))
        {
            sb.AppendLine();
            sb.AppendLine($"🔗 URL Ticket / CR / Backlog:");
            sb.AppendLine(att.UrlTicket);
        }
        sb.AppendLine($"👤 Cliente: {att.ClienteNome ?? "-"}");
        sb.AppendLine($"⏱️ Ore Lavorate: {att.OreLavorate}");
        if (!string.IsNullOrEmpty(att.Versione))
            sb.AppendLine($"🏷️ Versione: {att.Versione}");
        if (!string.IsNullOrEmpty(att.Vedere))
        {
            sb.AppendLine();
            sb.AppendLine($"👀 Vedere:");
            sb.AppendLine(att.Vedere);
        }
        if (!string.IsNullOrEmpty(att.CartellaDocumentazione))
        {
            sb.AppendLine();
            sb.AppendLine($"📁 Cartella Documentazione:");
            sb.AppendLine(att.CartellaDocumentazione);
        }
        if (!string.IsNullOrEmpty(att.Note))
        {
            sb.AppendLine();
            sb.AppendLine($"📋 Descrizione dettagliata lavoro svolto:");
            sb.AppendLine(HtmlToPlainText(att.Note));
        }
        if (!string.IsNullOrEmpty(att.TestoCheckIn))
        {
            sb.AppendLine();
            sb.AppendLine($"✏️ Testo del check-in:");
            sb.AppendLine(att.TestoCheckIn);
        }
        if (!string.IsNullOrEmpty(att.ChangesetCoinvolti))
        {
            sb.AppendLine();
            sb.AppendLine($"🔢 Elenco Changeset e lista files coinvolti:");
            sb.AppendLine(HtmlToPlainText(att.ChangesetCoinvolti));
        }
        if (!string.IsNullOrEmpty(att.UrlPatchRilasci))
        {
            sb.AppendLine();
            sb.AppendLine($"📦 URL Patch/Pacchetto nei rilasci:");
            sb.AppendLine(att.UrlPatchRilasci);
        }
        return sb.ToString().TrimEnd();
    }

    /// <summary>
    /// Rimuove i tag HTML da una stringa e decodifica le entità HTML di base.
    /// Usato per la generazione di testi plain da campi che possono contenere HTML.
    /// </summary>
    private static string HtmlToPlainText(string? html)
    {
        if (string.IsNullOrEmpty(html)) return string.Empty;
        // Sostituisce <br>, </p> e </div> con newline (i contenteditable usano <div> per gli a capo)
        html = System.Text.RegularExpressions.Regex.Replace(html, @"<br\s*/?>", "\n", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"</p>", "\n", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"</div>", "\n", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        // Rimuove tutti gli altri tag
        html = System.Text.RegularExpressions.Regex.Replace(html, @"<[^>]+>", string.Empty);
        // Decodifica entità HTML di base
        html = html.Replace("&amp;", "&").Replace("&lt;", "<").Replace("&gt;", ">")
                   .Replace("&nbsp;", " ").Replace("&quot;", "\"").Replace("&#39;", "'");
        // Normalizza newline multipli consecutivi (max 2) per pulizia
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\n{3,}", "\n\n");
        return html;
    }

    #endregion

    #region Utility

    /// <summary>
    /// Mostra un messaggio di feedback all'utente.
    /// </summary>
    private void MostraMessaggio(string testo, bool errore)
    {
        messaggio = testo;
        isErrore = errore;
    }

    /// <summary>
    /// Mostra il messaggio e, per errori critici (salvataggio/connessione DB),
    /// mostra anche una popup modale in modo da non passare inosservata.
    /// </summary>
    private void MostraMessaggioConPopup(string testo, bool errore)
    {
        MostraMessaggio(testo, errore);
        if (errore)
        {
            messaggioPopupErroreDb = testo;
            mostraPopupErroreDb = true;
        }
    }

    /// <summary>
    /// Tronca un testo alla lunghezza specificata, aggiungendo "..." se necessario.
    /// </summary>
    private string TruncateText(string? text, int maxLength)
    {
        if (string.IsNullOrEmpty(text))
            return "-";
        return text.Length > maxLength ? text[..maxLength] + "..." : text;
    }

    /// <summary>
    /// Verifica se un'attività contiene la parola TODO come parola isolata
    /// (non come parte di un'altra parola, es: "metodo" non conta).
    /// Usa regex con word boundary per maggiore precisione.
    /// </summary>
    private bool ContieneTodo(WorkActivityDto attivita)
    {
        return TodoRegex.IsMatch(attivita.Descrizione ?? "")
            || TodoRegex.IsMatch(HtmlToPlainText(attivita.Note))
            || TodoRegex.IsMatch(HtmlToPlainText(attivita.ChangesetCoinvolti))
            || TodoRegex.IsMatch(attivita.UrlTicket ?? "");
    }

    /// <summary>
    /// Verifica se uno specifico campo di testo contiene TODO come parola isolata.
    /// Usato per evidenziare con bordo rosso il campo corrispondente nel form
    /// quando l'attività selezionata contiene TODO.
    /// </summary>
    private bool CampoHaTodo(string? campo) =>
        IsModifica && !string.IsNullOrEmpty(campo) && TodoRegex.IsMatch(HtmlToPlainText(campo));

    // ===== Regex per rilevare URL nel campo UrlTicket =====
    private static readonly System.Text.RegularExpressions.Regex UrlRegex =
        new(@"https?://[^\s]+", System.Text.RegularExpressions.RegexOptions.IgnoreCase);

    /// <summary>
    /// Record che rappresenta un segmento di testo (URL o testo plain) per la visualizzazione cliccabile.
    /// </summary>
    private record UrlSegmento(string Testo, bool IsUrl);

    /// <summary>
    /// Verifica se il testo contiene almeno un URL http/https.
    /// </summary>
    private static bool ContienUrl(string? testo) =>
        !string.IsNullOrEmpty(testo) && UrlRegex.IsMatch(testo);

    /// <summary>
    /// Divide il testo in segmenti URL e non-URL per la visualizzazione cliccabile.
    /// </summary>
    private static List<UrlSegmento> ParseUrlSegmenti(string? testo)
    {
        var result = new List<UrlSegmento>();
        if (string.IsNullOrEmpty(testo)) return result;

        var lastIndex = 0;
        foreach (System.Text.RegularExpressions.Match m in UrlRegex.Matches(testo))
        {
            if (m.Index > lastIndex)
                result.Add(new UrlSegmento(testo[lastIndex..m.Index], false));
            result.Add(new UrlSegmento(m.Value, true));
            lastIndex = m.Index + m.Length;
        }
        if (lastIndex < testo.Length)
            result.Add(new UrlSegmento(testo[lastIndex..], false));

        return result;
    }

    /// <summary>
    /// Apre un URL nel browser predefinito del sistema.
    /// </summary>
    private void ApriUrl(string url)
    {
        try
        {
            Process.Start(new ProcessStartInfo
            {
                FileName = url,
                UseShellExecute = true
            });
        }
        catch { /* Ignora errori di apertura URL */ }
    }

    /// <summary>
    /// Aggiunge il metodo per copiare il TestoCheckIn nel campo Descrizione.
    /// </summary>
    private void CopiaCheckInInDescrizione()
    {
        if (!string.IsNullOrWhiteSpace(AttivitaCorrente.TestoCheckIn))
            AttivitaCorrente.Descrizione = AttivitaCorrente.TestoCheckIn;
    }

    /// <summary>
    /// Genera la rappresentazione testuale di un'attività (formato leggibile per incolla/email).
    /// Simile al formato della Ricerca Avanzata, senza HTML.
    /// </summary>
    private string GeneraTestoAttivita(WorkActivityDto att)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"📅 Data: {att.Data:dd/MM/yyyy}");
        if (!string.IsNullOrEmpty(att.TipoAttivita) && att.TipoAttivita != TipiAttivita.Lavoro)
            sb.AppendLine($"🏷️ Tipo: {att.TipoAttivita}");
        sb.AppendLine($"📝 Descrizione: {att.Descrizione ?? "-"}");
        if (!string.IsNullOrEmpty(att.UrlTicket))
        {
            sb.AppendLine();
            sb.AppendLine($"🔗 URL Ticket / CR / Backlog:");
            sb.AppendLine(att.UrlTicket);
        }
        sb.AppendLine($"👤 Cliente: {att.ClienteNome ?? "-"}");
        sb.AppendLine($"⏱️ Ore Lavorate: {att.OreLavorate}");
        if (!string.IsNullOrEmpty(att.Versione))
            sb.AppendLine($"🏷️ Versione: {att.Versione}");
        if (!string.IsNullOrEmpty(att.Vedere))
        {
            sb.AppendLine();
            sb.AppendLine($"👀 Vedere:");
            sb.AppendLine(att.Vedere);
        }
        if (!string.IsNullOrEmpty(att.CartellaDocumentazione))
        {
            sb.AppendLine();
            sb.AppendLine($"📁 Cartella Documentazione:");
            sb.AppendLine(att.CartellaDocumentazione);
        }
        if (!string.IsNullOrEmpty(att.Note))
        {
            sb.AppendLine();
            sb.AppendLine($"📋 Descrizione dettagliata lavoro svolto:");
            sb.AppendLine(HtmlToPlainText(att.Note));
        }
        if (!string.IsNullOrEmpty(att.TestoCheckIn))
        {
            sb.AppendLine();
            sb.AppendLine($"✏️ Testo del check-in:");
            sb.AppendLine(att.TestoCheckIn);
        }
        if (!string.IsNullOrEmpty(att.ChangesetCoinvolti))
        {
            sb.AppendLine();
            sb.AppendLine($"🔢 Elenco Changeset e lista files coinvolti:");
            sb.AppendLine(HtmlToPlainText(att.ChangesetCoinvolti));
        }
        if (!string.IsNullOrEmpty(att.UrlPatchRilasci))
        {
            sb.AppendLine();
            sb.AppendLine($"📦 URL Patch/Pacchetto nei rilasci:");
            sb.AppendLine(att.UrlPatchRilasci);
        }
        return sb.ToString().TrimEnd();
    }

    /// <summary>
    /// Copia la rappresentazione testuale dell'attività negli appunti di sistema.
    /// </summary>
    private async Task CopiaAttivitaComeTesto(WorkActivityDto attivita)
    {
        try
        {
            var testo = GeneraTestoAttivita(attivita);
            await JS.InvokeVoidAsync("copyToClipboard", testo);
            MostraMessaggio("Attività copiata negli appunti!", false);
        }
        catch (Exception ex)
        {
            MostraMessaggio($"Errore durante la copia: {ex.Message}", true);
        }
    }

    /// <summary>
    /// Restituisce il markup HTML del badge per il tipo attività (da renderizzare come MarkupString).
    /// </summary>
    private MarkupString GetTipoBadge(string? tipo)
    {
        return (tipo ?? TipiAttivita.Lavoro) switch
        {
            TipiAttivita.Permesso => new MarkupString("<span class=\"badge bg-warning text-dark\">🕐 Permesso</span>"),
            TipiAttivita.Ferie    => new MarkupString("<span class=\"badge bg-info text-dark\">🏖️ Ferie</span>"),
            TipiAttivita.Lavoro   => new MarkupString("<span class=\"badge bg-light text-dark\">💼</span>"),
            var t => new MarkupString($"<span class=\"badge bg-secondary text-white\">📌 {System.Net.WebUtility.HtmlEncode(t)}</span>")
        };
    }

    /// <summary>
    /// Determina la classe CSS per una riga della griglia.
    /// Gestisce sia la selezione che l'evidenziazione TODO.
    /// </summary>
    private string GetRowClass(WorkActivityDto attivita)
    {
        var classes = new List<string>();

        // Riga selezionata (colore giallo vivace per distinguerla facilmente)
        if (AttivitaCorrente.Id == attivita.Id)
        {
            classes.Add("row-selected");
        }

        // Riga con TODO (sfondo rosso)
        if (ContieneTodo(attivita))
        {
            classes.Add("todo-row");
        }

        // Riga con zero ore (testo grigio in corsivo)
        if (attivita.OreLavorate == 0)
        {
            classes.Add("zero-ore-row");
        }

        return string.Join(" ", classes);
    }

