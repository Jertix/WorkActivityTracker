@page "/"
@using WorkActivityTracker.Models
@using WorkActivityTracker.Services
@using CommunityToolkit.Maui.Storage
@using System.Diagnostics
@inject ActivityService ActivityService
@inject UserService UserService
@inject TodoService TodoService
@inject AmbienteService AmbienteService
@inject AppuntiService AppuntiService
@inject AppConfigService AppConfig
@inject IJSRuntime JS
@inject UnsavedChangesService UnsavedChanges
@inject ClienteService ClienteService
@inject SegnalazioneService SegnalazioneService
@inject AmbientiRilascioService AmbientiRilascioService
@inject TipiAttivitaService TipiAttivitaService
@inject CalendarioService CalendarioService
@inject EditorHistoryService EditorHistoryService
@implements IDisposable

@* 
    Pagina principale dell'applicazione Work Activity Tracker.
    Permette di visualizzare, creare, modificare ed eliminare attività lavorative.
    Supporta filtri per data, ricerca testuale e modalità admin.
*@

<div class="container-fluid p-3 main-content">
    
    @* ===== BARRA SUPERIORE: Utente, TODO e Modalità Admin ===== *@
    <div class="alert alert-info d-flex justify-content-between align-items-center mb-3">
        <div>
            <strong>👤 Utente connesso:</strong> @utenteConnesso
        </div>
        <div class="d-flex align-items-center gap-3">
            @* Pulsante Segnala (sempre visibile, indipendente dalla modalità admin) *@
            <button class="btn btn-danger btn-sm position-relative" @onclick="ApriSegnalazioni"
                    title="Segnala un bug nel programma o una richiesta di modifica">
                🐛 Segnala
                @if (segnalazioniCount > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark">
                        @segnalazioniCount
                        <span class="visually-hidden">segnalazioni aperte</span>
                    </span>
                }
            </button>
            @* Pulsante TODO List *@
            <button class="btn btn-warning btn-sm position-relative" @onclick="ApriTodoList">
                📋 TODO List
                @if (todoCount > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                        @todoCount
                        <span class="visually-hidden">TODO da completare</span>
                    </span>
                }
            </button>
            @* Pulsante Appunti *@
            <button class="btn btn-success btn-sm position-relative" @onclick="ApriAppunti">
                📌 Appunti
                @if (appuntiCount > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-info">
                        @appuntiCount
                        <span class="visually-hidden">Appunti salvati</span>
                    </span>
                }
            </button>
            @* Checkbox modalità admin (configurabile da appsettings.json) *@
            @if (AppConfig.MostraModalitaAdmin)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="adminMode" 
                           @bind="isAdminMode" @bind:after="OnAdminModeChanged" />
                    <label class="form-check-label" for="adminMode">
                        <strong>🔐 Modalità Admin</strong>
                    </label>
                </div>
            }
            <div class="d-flex align-items-center gap-2">
                <div class="text-muted small">
                    @DateTime.Now.ToString("dddd, dd MMMM yyyy")
                </div>
                <button class="btn btn-outline-primary btn-sm py-0 px-2" @onclick="ApriCalendario"
                        title="Calendario eventi e promemoria">
                    📅
                </button>
            </div>
        </div>
    </div>

    @* ===== BARRA AVVISI CALENDARIO ===== *@
    @if (eventiImminenti.Any())
    {
        var eventoUrgente = eventiImminenti.OrderBy(e => e.GiorniRimanenti).First();
        var gg = eventoUrgente.GiorniRimanenti;
        string barraCss, barraIcona, barraTestoGiorni;
        if (gg < 0)
        {
            barraCss = "alert-secondary";
            barraIcona = "⏰";
            barraTestoGiorni = $"{(int)Math.Abs(gg)} giorni fa è scaduto";
        }
        else if (gg < 1)
        {
            barraCss = "alert-danger";
            barraIcona = "🔴";
            barraTestoGiorni = "oggi";
        }
        else if (gg <= 2)
        {
            barraCss = "alert-danger";
            barraIcona = "🔴";
            barraTestoGiorni = $"fra {(int)gg} giorni";
        }
        else if (gg <= 5)
        {
            barraCss = "alert-warning";
            barraIcona = "🟠";
            barraTestoGiorni = $"fra {(int)gg} giorni";
        }
        else
        {
            barraCss = "alert-success";
            barraIcona = "🟢";
            barraTestoGiorni = $"fra {(int)gg} giorni";
        }
        var tutteLeDescrizioni = string.Join(", ", eventiImminenti.Select(e => $"\"{e.Descrizione}\""));
        <div class="alert @barraCss py-2 mb-2 d-flex justify-content-between align-items-center" role="alert">
            <span>
                @barraIcona
                @if (gg < 1 && gg >= 0)
                {
                    <strong>@barraTestoGiorni: @tutteLeDescrizioni</strong>
                }
                else if (gg < 0)
                {
                    <span>@barraTestoGiorni: @tutteLeDescrizioni — <em>rimuoverlo dal calendario</em></span>
                }
                else
                {
                    <span>@tutteLeDescrizioni @barraTestoGiorni</span>
                }
            </span>
            <button class="btn btn-sm btn-outline-secondary py-0" @onclick="ApriCalendario" title="Apri calendario per gestire gli eventi">
                📅
            </button>
        </div>
    }

    @* ===== MESSAGGI DI FEEDBACK ===== *@
    @if (!string.IsNullOrEmpty(messaggio))
    {
        <div class="alert @(isErrore ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
            @messaggio
            <button type="button" class="btn-close" @onclick="() => messaggio = string.Empty"></button>
        </div>
    }

    @* ===== SEZIONE FILTRI ===== *@
    <div class="row mb-3">
        @* Filtro Anno *@
        <div class="col-md-2">
            <label class="form-label">Anno</label>
            <div class="d-flex gap-1">
                <select class="form-select" @bind="FiltroAnno" @bind:after="CaricaAttivita">
                    <option value="">Tutti</option>
                    @foreach (var anno in anniDisponibili)
                    {
                        <option value="@anno">@anno</option>
                    }
                </select>
                <button class="btn btn-outline-primary btn-sm" @onclick="ImpostaAnnoCorrente"
                        title="Seleziona l'anno corrente e azzera mese e giorno"
                        style="white-space: nowrap; min-width: 46px;">
                    @DateTime.Now.Year
                </button>
            </div>
        </div>

        @* Filtro Mese *@
        <div class="col-md-2">
            <label class="form-label">Mese</label>
            <div class="d-flex gap-1">
                <select class="form-select" @bind="FiltroMese" @bind:after="CaricaAttivita">
                    <option value="">Tutti</option>
                    @for (int mese = 1; mese <= 12; mese++)
                    {
                        <option value="@mese">@(new DateTime(2000, mese, 1).ToString("MMMM"))</option>
                    }
                </select>
                <button class="btn btn-outline-success btn-sm" @onclick="ImpostaMeseCorrente"
                        title="Seleziona anno e mese correnti, azzera il giorno"
                        style="white-space: nowrap; min-width: 60px;">
                    @(new DateTime(2000, DateTime.Now.Month, 1).ToString("MMM"))
                </button>
            </div>
        </div>
        
        @* Filtro Giorno + bottone Oggi *@
        <div class="col-md-2">
            <label class="form-label">Giorno</label>
            <div class="d-flex gap-1">
                <select class="form-select" @bind="FiltroGiorno" @bind:after="CaricaAttivita">
                    <option value="">Tutti</option>
                    @for (int giorno = 1; giorno <= 31; giorno++)
                    {
                        bool hasContext = FiltroAnno.HasValue && FiltroMese.HasValue;
                        bool dayExists = hasContext && giorno <= DateTime.DaysInMonth(FiltroAnno!.Value, FiltroMese!.Value);
                        if (!hasContext || dayExists)
                        {
                            string prefix = "";
                            if (dayExists)
                            {
                                var dt = new DateTime(FiltroAnno!.Value, FiltroMese!.Value, giorno);
                                bool isToday = dt.Date == DateTime.Today;
                                bool isWeekend = dt.DayOfWeek == DayOfWeek.Saturday || dt.DayOfWeek == DayOfWeek.Sunday;
                                prefix = isToday ? "🟢 " : isWeekend ? "🟠 " : "";
                            }
                            string label = dayExists
                                ? $"{prefix}{giorno} - {new DateTime(FiltroAnno!.Value, FiltroMese!.Value, giorno).ToString("ddd", new System.Globalization.CultureInfo("it-IT"))}"
                                : giorno.ToString();
                            <option value="@giorno">@label</option>
                        }
                    }
                </select>
                <button class="btn btn-outline-primary btn-sm" @onclick="ImpostaOggi"
                        title="Premi per selezionare in automatico la data di oggi"
                        style="white-space: nowrap; min-width: 46px;">
                    📅 Oggi
                </button>
            </div>
        </div>
        
        @* Campo Ricerca *@
        <div class="col-md-4">
            <label class="form-label">Ricerca</label>
            <div class="input-group">
                <input type="text" class="form-control" @bind="TestoRicerca" @bind:event="oninput" 
                       @onkeypress="OnSearchKeyPress" placeholder="Cerca in descrizione, ticket, note..." />
                <button class="btn btn-primary" @onclick="EseguiRicercaEAbilita">
                    🔍 Cerca
                </button>
                <button class="btn btn-info" 
                        @onclick="ApriDettagliRicerca"
                        title="Apri ricerca avanzata">
                    🔍 Ricerca avanzata
                </button>
            </div>
        </div>
        
        @* Bottone Reset Filtri *@
        <div class="col-md-2 d-flex align-items-end">
            <button class="btn btn-outline-secondary w-100" @onclick="ResetFiltri">
                🔄 Reset Filtri
            </button>
        </div>
    </div>
    
    @* ===== FILTRO SOLO TODO ===== *@
    <div class="row mb-3">
        <div class="col-12">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="chkSoloTodo" 
                       @bind="filtroSoloTodo" @bind:after="CaricaAttivita" 
                       style="transform: scale(1.3);" />
                <label class="form-check-label fw-bold text-danger" for="chkSoloTodo" style="font-size: 1.1em;">
                    📌 Visualizza solo TODO
                </label>
                @if (filtroSoloTodo)
                {
                    <span class="badge bg-danger ms-2">Filtro attivo</span>
                }
            </div>
        </div>
    </div>

    @* ===== GRIGLIA ATTIVITÀ ===== *@
    <div class="row">
        <div class="col-md-12 mb-3">
            @if (isLoading)
            {
                <div class="text-center p-3">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Caricamento...</span>
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                    <table class="table table-striped table-hover table-sm">
                        <thead class="table-dark sticky-top">
                            <tr>
                                @if (isAdminMode)
                                {
                                    <th>Utente</th>
                                }
                                <th>Data</th>
                                <th>Tipo</th>
                                <th>N° Ticket</th>
                                <th>Descrizione</th>
                                <th>Cliente</th>
                                <th>Ore</th>
                                <th>Versione</th>
                                <th>Ambienti</th>
                                <th>Patch</th>
                                <th title="Cartella documentazione">Cart. Doc.</th>
                                <th>Azioni</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Attivita.Any())
                            {
                                @foreach (var att in Attivita)
                                {
                                    <tr @onclick="() => SelezionaAttivita(att)"
                                        class="@GetRowClass(att)"
                                        style="cursor: pointer;">
                                        @if (isAdminMode)
                                        {
                                            <td><span class="badge bg-secondary">@att.UtenteUsername</span></td>
                                        }
                                        <td>@att.Data.ToString("dd/MM/yyyy")</td>
                                        <td>@GetTipoBadge(att.TipoAttivita)</td>
                                        <td>@TruncateText(att.NumeroTicket, 20)</td>
                                        <td>
                                            @TruncateText(att.Descrizione, 50)
                                            @if (ContieneTodo(att))
                                            {
                                                <span class="todo-badge">TODO</span>
                                            }
                                        </td>
                                        <td>@(att.ClienteNome ?? "-")</td>
                                        <td>@att.OreLavorate</td>
                                        <td>@TruncateText(att.Versione, 20)</td>
                                        <td style="white-space: nowrap; font-size: 0.8em;">@(att.AmbientiRilascioNomi ?? "")</td>
                                        <td class="text-center">
                                            @if (!string.IsNullOrWhiteSpace(att.UrlPatchRilasci))
                                            {
                                                <span style="color: green; font-weight: bold;">✔</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (!string.IsNullOrWhiteSpace(att.CartellaDocumentazione))
                                            {
                                                <span style="color: green;" title="@att.CartellaDocumentazione">📁</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-secondary me-1"
                                                    @onclick="() => CopiaAttivitaComeTesto(att)"
                                                    @onclick:stopPropagation="true"
                                                    title="Copia attività come testo negli appunti">
                                                📄
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary me-1"
                                                    @onclick="() => EsportaAttivitaComeTxt(att)"
                                                    @onclick:stopPropagation="true"
                                                    title="Esporta attività come testo su file txt">
                                                💾
                                            </button>
                                            <button class="btn btn-sm btn-info me-1"
                                                    @onclick="() => DuplicaAttivita(att)"
                                                    @onclick:stopPropagation="true"
                                                    title="Duplica attività (copia tutti i campi tranne la data)">
                                                📋
                                            </button>
                                            <button class="btn btn-sm btn-danger"
                                                    @onclick="() => ConfermaEliminaAttivita(att)"
                                                    @onclick:stopPropagation="true"
                                                    disabled="@(isAdminMode && att.UtenteUsername != UserService.WindowsUsername)"
                                                    title="Elimina attività del @att.Data.ToString("dd/MM/yyyy"): @att.Descrizione">
                                                🗑️
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="@(isAdminMode ? 11 : 10)" class="text-center text-muted">
                                        Nessuna attività trovata
                                    </td>
                                </tr>
                            }
                        </tbody>
                        @if (Attivita.Any())
                        {
                            <tfoot class="table-secondary fw-bold">
                                <tr>
                                    <td colspan="@(isAdminMode ? 5 : 4)" class="text-end">Totale ore visualizzate:</td>
                                    <td>@Attivita.Sum(a => a.OreLavorate).ToString("N2")</td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-1 flex-wrap gap-1">
                    <div class="text-muted small">
                        Totale: @Attivita.Count attività
                        @if (isAdminMode)
                        {
                            <span class="ms-2 badge bg-warning text-dark">👁️ Visualizzazione Admin</span>
                        }
                    </div>
                    @if (Attivita.Any())
                    {
                        <div class="d-flex gap-1 flex-wrap">
                            <button class="btn btn-outline-success btn-sm" @onclick="EsportaGrigliaXlsx"
                                    title="Esporta la griglia visualizzata in formato Excel (.xlsx)">
                                📊 Esporta XLSX
                            </button>
                            <button class="btn btn-outline-primary btn-sm" @onclick="EsportaDettagliTxt"
                                    title="Esporta il dettaglio di tutte le attività visualizzate in un file TXT">
                                📄 Esporta dettagli TXT
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="ApriCartellaExport"
                                    title="Apri la cartella Export del programma">
                                📁 Apri Export
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @* ===== FORM DETTAGLIO ATTIVITÀ ===== *@
    <div class="card">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <strong>@(IsModifica ? "✏️ Modifica Attività" : "➕ Nuova Attività")</strong>
            <div class="d-flex align-items-center gap-2">
                @if (isAdminMode && IsModifica && !string.IsNullOrEmpty(AttivitaCorrente.UtenteUsername))
                {
                    <span class="badge bg-warning text-dark">
                        👤 @AttivitaCorrente.UtenteUsername
                    </span>
                }
                @if (IsModifica)
                {
                    <span class="badge bg-light text-dark">ID: @AttivitaCorrente.Id</span>
                }
                @* Bottoni rapidi in cima *@
                <button class="btn btn-success btn-sm py-0 px-2" @onclick="NuovaAttivita" disabled="@isSaving" title="Nuova attività">
                    ➕ Nuova
                </button>
                <button class="btn btn-light btn-sm py-0 px-2" @onclick="SalvaAttivita"
                        disabled="@(isSaving || (isAdminMode && IsModifica && AttivitaCorrente.UtenteUsername != UserService.WindowsUsername))"
                        title="Salva attività (Ctrl+S)">
                    💾 Salva
                </button>
                <button class="btn btn-secondary btn-sm py-0 px-2" @onclick="AnnullaModifica" disabled="@isSaving" title="Annulla modifiche">
                    ❌ Annulla
                </button>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                
                @* ===== PRIMA RIGA: Tipo Attività, Data, Cliente, Ore, Versione ===== *@
                <div class="col-md-2">
                    <label class="form-label">Tipo Attività</label>
                    <div class="input-group">
                        <select class="form-select @(AttivitaCorrente.TipoAttivita != TipiAttivita.Lavoro ? "border-warning fw-bold" : "")"
                                @bind="AttivitaCorrente.TipoAttivita">
                            @foreach (var tipo in tipiAttivitaLista)
                            {
                                var emoji = tipo.Nome == TipiAttivita.Lavoro ? "💼" :
                                            tipo.Nome == TipiAttivita.Permesso ? "🕐" :
                                            tipo.Nome == TipiAttivita.Ferie ? "🏖️" : "📌";
                                <option value="@tipo.Nome">@emoji @tipo.Nome</option>
                            }
                        </select>
                        <button class="btn btn-outline-secondary btn-sm" type="button"
                                @onclick="ApriEditorTipiAttivita"
                                title="Gestisci tipi attività">
                            ✏️
                        </button>
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Data <span class="text-danger">*</span></label>
                    <input type="date" class="form-control" @bind="AttivitaCorrente.Data" />
                </div>
                @if (AttivitaCorrente.TipoAttivita == TipiAttivita.Lavoro)
                {
                    <div class="col-md-3">
                        <label class="form-label">Cliente</label>
                        <div class="input-group">
                            <select class="form-select" @bind="AttivitaCorrente.ClienteId">
                                @foreach (var cliente in clientiOrdinati)
                                {
                                    <option value="@cliente.Id">@cliente.Nome</option>
                                }
                            </select>
                            <button class="btn btn-outline-secondary btn-sm" type="button"
                                    @onclick="ApriEditorClienti"
                                    title="Gestisci lista clienti">
                                ✏️
                            </button>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Ore Lavorate <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" @bind="AttivitaCorrente.OreLavorate" min="0" max="24" step="0.5" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Versione di sviluppo</label>
                        <input type="text" class="form-control" @bind="AttivitaCorrente.Versione" placeholder="@VersioneSviluppoPlaceholder" />
                    </div>
                }
                else
                {
                    <div class="col-md-2">
                        <label class="form-label">Ore @(AttivitaCorrente.TipoAttivita == TipiAttivita.Ferie ? "(0 = giorno intero)" : "")</label>
                        <input type="number" class="form-control" @bind="AttivitaCorrente.OreLavorate" min="0" max="24" step="0.5" />
                    </div>
                    <div class="col-md-6">
                        @if (AttivitaCorrente.TipoAttivita == TipiAttivita.Permesso ||
                             AttivitaCorrente.TipoAttivita == TipiAttivita.Ferie)
                        {
                            <label class="form-label text-muted small">I campi Cliente, Versione, Ticket e Congelati non si applicano per @AttivitaCorrente.TipoAttivita.</label>
                        }
                        else
                        {
                            <label class="form-label text-muted small">I campi Cliente, Versione e Congelati non si applicano per @AttivitaCorrente.TipoAttivita.</label>
                        }
                    </div>
                }

                @* ===== RIGA AMBIENTI DI RILASCIO (solo Lavoro + cliente != Sviluppo) ===== *@
                @if (AttivitaCorrente.TipoAttivita == TipiAttivita.Lavoro && AttivitaCorrente.ClienteId != clienteSviluppoId)
                {
                    <div class="col-md-12">
                        <label class="form-label">Ambienti di rilascio</label>
                        <div class="d-flex flex-wrap gap-2 align-items-center">
                            @for (int i = 0; i < 3; i++)
                            {
                                var idx = i;
                                var coppia = AttivitaCorrente.AmbientiRilascio[idx];
                                var listIdTipo = $"tipi-rilascio-list-{idx}";
                                var listIdVer = $"versioni-rilascio-list-{idx}";
                                <div class="d-flex gap-1 align-items-center">
                                    <input list="@listIdTipo"
                                           class="form-control form-control-sm"
                                           style="width: 160px;"
                                           placeholder="Selezionare"
                                           @bind="coppia.TipoAmbiente"
                                           title="Tipo ambiente (es: Test, Qualità, Pre-produzione, Produzione)" />
                                    <datalist id="@listIdTipo">
                                        @foreach (var tipo in tipiAmbientiRilascio)
                                        {
                                            <option value="@tipo.Nome" />
                                        }
                                    </datalist>
                                    <input list="@listIdVer"
                                           class="form-control form-control-sm"
                                           style="width: 190px;"
                                           placeholder="Selezionare"
                                           @bind="coppia.Versione"
                                           title="Versione di rilascio (es: 3.2.50, 4.1.10 (3.2.60))" />
                                    <datalist id="@listIdVer">
                                        @foreach (var ver in versioniRilascio)
                                        {
                                            <option value="@ver.Versione" />
                                        }
                                    </datalist>
                                    @if (idx < 2)
                                    {
                                        <span class="text-muted px-1">─</span>
                                    }
                                </div>
                            }
                        </div>
                        <small class="text-muted">I valori inseriti verranno aggiunti automaticamente alla lista per i prossimi utilizzi.</small>
                    </div>
                }

                @* ===== SECONDA RIGA: Descrizione ===== *@
                <div class="col-md-12">
                    <label class="form-label">Descrizione <span class="text-danger">*</span></label>
                    <input type="text" class="form-control fw-bold @(CampoHaTodo(AttivitaCorrente.Descrizione) ? "campo-con-todo" : "")"
                           @bind="AttivitaCorrente.Descrizione"
                           placeholder="@(AttivitaCorrente.TipoAttivita == TipiAttivita.Lavoro ? "Descrizione breve dell'attività" : $"Es: {AttivitaCorrente.TipoAttivita} dal ... al ...")" />
                </div>

                @* ===== TERZA RIGA: URL Ticket + Numero Ticket (visibile per Lavoro e tipi personalizzati) ===== *@
