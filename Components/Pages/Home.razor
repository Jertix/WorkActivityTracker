    {
        <span>💾 Ultimo salvataggio: @ultimoSalvataggio.Value.ToString("HH:mm:ss")</span>
    }
    else
    {
        <span class="text-secondary">💾 Nessun salvataggio in questa sessione</span>
    }
    @if (!string.IsNullOrEmpty(ultimoExport))
    {
        <span title="@ultimoExport">📤 Export: @System.IO.Path.GetFileName(ultimoExport)</span>
    }
    @if (isAdminMode)
    {
        <span class="badge bg-warning text-dark">🔐 Modalità Admin attiva</span>
    }
    @if (AppConfig.PrivacyMode)
    {
        <span class="badge bg-info text-dark">🔒 Privacy attiva</span>
    }
    <span class="ms-auto text-secondary">v@(AppConfig.Version)</span>
</div>

@code {
    #region Proprietà e Campi

    /// <summary>Lista delle attività visualizzate nella griglia</summary>
    private List<WorkActivityDto> Attivita { get; set; } = new();
    
    /// <summary>Attività attualmente selezionata/in modifica nel form</summary>
    private WorkActivityDto AttivitaCorrente { get; set; } = new();
    
    /// <summary>True se si sta modificando un'attività esistente (ID > 0)</summary>
