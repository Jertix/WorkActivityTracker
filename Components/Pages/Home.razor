    /// </summary>
    private string GetExportFolder()
    {
        var folder = System.IO.Path.Combine(AppContext.BaseDirectory, "Export");
        System.IO.Directory.CreateDirectory(folder);
        return folder;
    }

    /// <summary>
    /// Esporta la griglia visualizzata in formato Excel (.xlsx).
    /// </summary>
    private async Task EsportaGrigliaXlsx()
    {
        try
        {
            var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");
            var nomeFile = $"ElencoAttivitàAl{timestamp}.xlsx";
            var percorso = System.IO.Path.Combine(GetExportFolder(), nomeFile);

            using var wb = new ClosedXML.Excel.XLWorkbook();
            var ws = wb.Worksheets.Add("Attività");

            // Intestazioni
            int col = 1;
            if (isAdminMode) ws.Cell(1, col++).Value = "Utente";
            ws.Cell(1, col++).Value = "Data";
            ws.Cell(1, col++).Value = "Tipo";
            ws.Cell(1, col++).Value = "Descrizione";
            ws.Cell(1, col++).Value = "Cliente";
            ws.Cell(1, col++).Value = "Ore";
            ws.Cell(1, col++).Value = "Versione";

            // Stile intestazioni
            var headerRow = ws.Row(1);
            headerRow.Style.Font.Bold = true;
            headerRow.Style.Fill.BackgroundColor = ClosedXML.Excel.XLColor.DarkGray;
            headerRow.Style.Font.FontColor = ClosedXML.Excel.XLColor.White;

            // Dati
            int row = 2;
            foreach (var att in Attivita)
            {
                col = 1;
                if (isAdminMode) ws.Cell(row, col++).Value = att.UtenteUsername;
                ws.Cell(row, col).Style.NumberFormat.Format = "dd/MM/yyyy";
                ws.Cell(row, col++).Value = att.Data;
                ws.Cell(row, col++).Value = att.TipoAttivita;
                ws.Cell(row, col++).Value = att.Descrizione;
                ws.Cell(row, col++).Value = att.ClienteNome;
                ws.Cell(row, col++).Value = att.OreLavorate;
                ws.Cell(row, col++).Value = att.Versione;
                row++;
            }

            ws.Columns().AdjustToContents();
            wb.SaveAs(percorso);

            ultimoExport = percorso;
            MostraMessaggio($"Esportato: {nomeFile}", false);
        }
        catch (Exception ex)
        {
            MostraMessaggio($"Errore export XLSX: {ex.Message}", true);
        }

        await Task.CompletedTask;
    }

    /// <summary>
    /// Esporta il dettaglio di tutte le attività visualizzate in un file TXT.
    /// </summary>
    private async Task EsportaDettagliTxt()
    {
        try
        {
            var dal = Attivita.Any() ? Attivita.Min(a => a.Data).ToString("yyyyMMdd") : "n_a";
            var al  = Attivita.Any() ? Attivita.Max(a => a.Data).ToString("yyyyMMdd") : "n_a";
            var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");
            var nomeFile = $"DettaglioTutteLeAttività_{dal}_{al}_{timestamp}.txt";
            var percorso = System.IO.Path.Combine(GetExportFolder(), nomeFile);

            var sb = new System.Text.StringBuilder();
            bool primo = true;
            foreach (var att in Attivita)
            {
                if (!primo) sb.AppendLine(new string('=', 60));
                sb.AppendLine(GeneraTestoAttivitaPlain(att));
                primo = false;
            }

            System.IO.File.WriteAllText(percorso, sb.ToString(), System.Text.Encoding.UTF8);
            ultimoExport = percorso;
            MostraMessaggio($"Esportato: {nomeFile}", false);
        }
        catch (Exception ex)
        {
            MostraMessaggio($"Errore export TXT: {ex.Message}", true);
        }

        await Task.CompletedTask;
    }

    /// <summary>
    /// Esporta una singola attività come file TXT.
    /// </summary>
    private async Task EsportaAttivitaComeTxt(WorkActivityDto att)
    {
        try
        {
            var data = att.Data.ToString("yyyyMMdd");
            var desc = string.Concat((att.Descrizione ?? "").Take(40)
                .Where(c => !System.IO.Path.GetInvalidFileNameChars().Contains(c)));
            var timestamp = DateTime.Now.ToString("HHmmss");
            var nomeFile = $"DettaglioAttività_{data}_{desc}_{timestamp}.txt";
            var percorso = System.IO.Path.Combine(GetExportFolder(), nomeFile);

            System.IO.File.WriteAllText(percorso, GeneraTestoAttivitaPlain(att), System.Text.Encoding.UTF8);
            ultimoExport = percorso;
            MostraMessaggio($"Esportato: {nomeFile}", false);
        }
        catch (Exception ex)
        {
            MostraMessaggio($"Errore export TXT: {ex.Message}", true);
        }

        await Task.CompletedTask;
    }

