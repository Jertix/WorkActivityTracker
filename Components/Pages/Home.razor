                            <button class="btn btn-outline-dark btn-sm fw-bold" type="button"
                                    @onclick="ChangesetBold"
                                    title="Applica/rimuovi grassetto al testo selezionato">
                                G
                            </button>
                            <button class="btn btn-sm" type="button"
                                    @onclick="ChangesetHighlightGiallo"
                                    title="Evidenzia in giallo il testo selezionato"
                                    style="background-color: yellow; border: 1px solid #ccc; font-size: 0.75rem; padding: 2px 7px;">
                                A
                            </button>
                            <button class="btn btn-sm" type="button"
                                    @onclick="ChangesetHighlightArancione"
                                    title="Evidenzia in arancione il testo selezionato"
                                    style="background-color: orange; border: 1px solid #ccc; font-size: 0.75rem; padding: 2px 7px;">
                                A
                            </button>
                            <div class="separator"></div>
                            <button class="btn btn-outline-secondary btn-sm" type="button"
                                    @onclick="ChangesetBarrato"
                                    title="Applica/rimuovi barrato al testo selezionato"
                                    style="text-decoration: line-through;">
                                S
                            </button>
                            <button class="btn btn-sm" type="button"
                                    @onclick="ChangesetColoreTessoRosso"
                                    title="Colora in rosso il testo selezionato"
                                    style="color: red; font-weight: bold; border: 1px solid #ccc; font-size: 0.75rem; padding: 2px 7px;">
                                A
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" type="button"
                                    @onclick="ChangesetRimuoviFormattazione"
                                    title="Rimuovi tutta la formattazione dal testo selezionato">
                                ✕
                            </button>
                            <div class="separator"></div>
                            <button class="btn btn-outline-secondary btn-sm" type="button"
                                    @onclick="ChangesetInserisciTimestamp"
                                    title="Inserisci l'ora corrente (HH:mm:ss) nel punto del cursore">
                                🕐
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" type="button"
                                    @onclick="ChangesetInserisciSeparatore"
                                    title="Inserisci una linea sottile di separazione nel punto del cursore">
                                ─
                            </button>
                            <button class="btn btn-outline-dark btn-sm" type="button"
                                    @onclick="ChangesetInserisciSeparatoreSpesso"
                                    title="Inserisci una linea spessa di separazione nel punto del cursore"
                                    style="font-weight: 900;">
                                █
                            </button>
                            <button class="btn btn-sm" type="button"
                                    @onclick="ChangesetInserisciSeparatoreRosso"
                                    title="Inserisci una linea spessa ROSSA di separazione nel punto del cursore"
                                    style="color: red; font-weight: 900; border: 1px solid #ccc; font-size: 0.75rem; padding: 2px 7px;">
                                █
                            </button>
                            <div class="separator"></div>
                            <button class="btn btn-outline-secondary btn-sm" type="button"
                                    @onclick="ChangesetRimuoviRigheVuote"
                                    title="Rimuovi le righe vuote dal contenuto dell'editor"
                                    @onmousedown:preventDefault>
                                ⊟
                            </button>
                            <button class="btn btn-outline-warning btn-sm" type="button"
                                    @onclick="ChangesetRimuoviTodo"
                                    title="Sostituisce TODO (parola isolata) con '--'"
                                    @onmousedown:preventDefault>
                                TODO
                            </button>
                        </div>
                    </div>

                    @* ===== NONA RIGA: URL Patch/Pacchetto nei rilasci ===== *@
                    <div class="col-12">
                        <label class="form-label">📦 URL Patch/Pacchetto nei rilasci</label>
                        <textarea class="form-control" @bind="AttivitaCorrente.UrlPatchRilasci" rows="3"
                                  style="max-height: 100px; overflow-y: auto;"
                                  placeholder="Inserisci gli URL della patch o del pacchetto nei rilasci..."></textarea>
                    </div>
                }
            </div>
        </div>
        
        @* ===== BOTTONI AZIONE ===== *@
        <div class="card-footer">
            <div class="d-flex gap-2">
                <button class="btn btn-success" @onclick="NuovaAttivita" disabled="@isSaving">
                    ➕ Nuova
                </button>
                <button class="btn btn-primary" @onclick="SalvaAttivita"
                        disabled="@(isSaving || (isAdminMode && IsModifica && AttivitaCorrente.UtenteUsername != UserService.WindowsUsername))"
                        title="Salva attività (Ctrl+S)">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    💾 Salva
                </button>
                <button class="btn btn-secondary" @onclick="AnnullaModifica" disabled="@isSaving">
                    ❌ Annulla
                </button>
            </div>
            @if (isAdminMode && IsModifica && AttivitaCorrente.UtenteUsername != UserService.WindowsUsername)
            {
                <small class="text-warning mt-2 d-block">
                    ⚠️ Non puoi modificare attività di altri utenti
                </small>
            }
        </div>
    </div>
</div>

