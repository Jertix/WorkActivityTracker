    private IEnumerable<Cliente> clientiOrdinati => 
        clienti.OrderByDescending(c => c.Nome == "Sviluppo").ThenBy(c => c.Nome);
    
    /// <summary>
    /// ID del cliente "Sviluppo" (cached per performance)
    /// </summary>
    private int? clienteSviluppoId => clienti.FirstOrDefault(c => c.Nome == "Sviluppo")?.Id;
    
    /// <summary>
    /// Flag per tracciare se "Sviluppo" è selezionato nella tabella congelati
    /// </summary>
    private bool isSviluppoSelezionato = false;

    /// <summary>
    /// Riferimento all'elemento DOM del changeset editor (contenteditable div)
    /// </summary>
    private ElementReference changesetEditorRef;

    /// <summary>
    /// True se l'utente ha il focus sull'editor changeset (per evitare sovrascritture)
    /// </summary>
    private bool changesetEditorFocused = false;

    /// <summary>
    /// Flag per forzare l'aggiornamento del contenteditable editor al prossimo render
    /// </summary>
    private bool changesetEditorNeedsUpdate = false;

    /// <summary>Riferimento all'elemento DOM dell'editor Note (contenteditable div)</summary>
    private ElementReference noteEditorRef;

    /// <summary>True se l'utente ha il focus sull'editor Note</summary>
    private bool noteEditorFocused = false;

    /// <summary>Flag per forzare l'aggiornamento dell'editor Note al prossimo render</summary>
    private bool noteEditorNeedsUpdate = false;

    /// <summary>Riferimento .NET per il callback Ctrl+S da JavaScript</summary>
    private DotNetObjectReference<Home>? dotNetRef;

    // ===== Storico versioni editor Note =====
    /// <summary>Lista versioni salvate per il campo Note (null = non ancora caricato)</summary>
    private List<EditorHistoryEntry>? _noteHistory;
    /// <summary>Indice di navigazione nello storico Note (-1 = stato corrente non salvato)</summary>
    private int _noteHistoryIndex = -1;
    /// <summary>Contenuto HTML corrente prima dell'inizio della navigazione undo Note</summary>
    private string? _noteContenutoSalvato;

    // ===== Storico versioni editor Changeset =====
    /// <summary>Lista versioni salvate per il campo ChangesetCoinvolti (null = non ancora caricato)</summary>
    private List<EditorHistoryEntry>? _changesetHistory;
    /// <summary>Indice di navigazione nello storico Changeset (-1 = stato corrente non salvato)</summary>
    private int _changesetHistoryIndex = -1;
    /// <summary>Contenuto HTML corrente prima dell'inizio della navigazione undo Changeset</summary>
    private string? _changesetContenutoSalvato;

    // ===== Visibilità modali storico =====
    /// <summary>Controlla la visibilità della modale storico Note</summary>
    private bool _mostraStoriciNote = false;
    /// <summary>Controlla la visibilità della modale storico Changeset</summary>
    private bool _mostraStoriciChangeset = false;

    /// <summary>ID utente corrente (cacheato da OnInitializedAsync)</summary>
    private int _utenteCorrenteId;

    /// <summary>Visibilità della modale editor clienti</summary>
    private bool mostraEditorClienti = false;

    /// <summary>Visibilità della modale segnalazioni</summary>
    private bool mostraSegnalazioni = false;

    /// <summary>Contatore delle segnalazioni non risolte (per il badge)</summary>
    private int segnalazioniCount = 0;

    /// <summary>Percorso dell'ultimo file esportato (mostrato nella barra di stato)</summary>
    private string ultimoExport = string.Empty;

    // Filtri di ricerca
    private int? FiltroAnno { get; set; }
    private int? FiltroMese { get; set; }
    private int? FiltroGiorno { get; set; }
    private string TestoRicerca { get; set; } = string.Empty;

    // Stati dell'interfaccia
    private bool isLoading = true;
    private bool isSaving = false;
    private string messaggio = string.Empty;
    private bool isErrore = false;
    
    /// <summary>Modalità admin: permette di visualizzare le attività di tutti gli utenti</summary>
    private bool isAdminMode = false;
    
    /// <summary>Indica se è stata eseguita una ricerca (abilita il tasto Dettagli ricerca)</summary>
    private bool ricercaEseguita = false;
    
    /// <summary>Controlla la visibilità della modale di ricerca avanzata</summary>
    private bool mostraModaleRicerca = false;
    
    /// <summary>Filtro per visualizzare solo le attività che contengono TODO</summary>
    private bool filtroSoloTodo = false;
    
    /// <summary>Lista completa delle attività per la ricerca nella modale</summary>
    private List<WorkActivityDto> attivitaTuttePerRicerca = new();
    
    /// <summary>Controlla la visibilità della modale TODO List</summary>
    private bool mostraTodoList = false;
    
    /// <summary>Contatore dei TODO non completati (per il badge)</summary>
    private int todoCount = 0;
    
    /// <summary>Controlla la visibilità della modale editor congelati</summary>
    private bool mostraEditorCongelati = false;

    /// <summary>Controlla la visibilità della modale Appunti</summary>
    private bool mostraAppunti = false;

    /// <summary>Contatore degli Appunti (per il badge)</summary>
    private int appuntiCount = 0;

    // ===== Conferma eliminazione (modale custom) =====
    /// <summary>Controlla la visibilità della modale di conferma eliminazione</summary>
    private bool mostraConfermaElimina = false;
    /// <summary>Attività da eliminare (in attesa di conferma)</summary>
    private WorkActivityDto? attivitaDaEliminare = null;

    // ===== Barra di stato =====
    /// <summary>Timestamp dell'ultimo salvataggio riuscito</summary>
    private DateTime? ultimoSalvataggio = null;

    /// <summary>Lista dei tipi ambienti di rilascio (per datalist)</summary>
    private List<TipoAmbienteRilascio> tipiAmbientiRilascio = new();

    /// <summary>Lista delle versioni di rilascio (per datalist)</summary>
    private List<VersioneRilascio> versioniRilascio = new();

    /// <summary>Lista dei tipi attività (caricata dal DB, usata nel dropdown)</summary>
    private List<TipoAttivitaItem> tipiAttivitaLista = new();

    /// <summary>Controlla la visibilità della modale editor tipi attività</summary>
    private bool mostraEditorTipiAttivita = false;

    /// <summary>Controlla la visibilità della modale calendario</summary>
    private bool mostraCalendario = false;

    /// <summary>Lista eventi imminenti (non risolti, entro finestra di avviso)</summary>
    private List<EventoCalendarioDto> eventiImminenti = new();

    // ===== Popup errore database =====
    /// <summary>Controlla la visibilità del popup di errore database</summary>
    private bool mostraPopupErroreDb = false;
    /// <summary>Messaggio da mostrare nel popup errore</summary>
    private string messaggioPopupErroreDb = string.Empty;

    // ===== Regex TODO con word boundary =====
    /// <summary>
    /// Regex per trovare TODO come parola isolata (non preceduta/seguita da lettera).
    /// Esclude occorrenze come "metodo" (che contiene "odo" ma non TODO come parola).
    /// </summary>
    private static readonly System.Text.RegularExpressions.Regex TodoRegex =
        new(@"(?<![a-zA-Z])TODO(?![a-zA-Z])",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);

    #endregion

    #region Lifecycle Methods

    /// <summary>
    /// Aggiorna i contenteditable div (changeset + note) dopo ogni render.
    /// Registra anche il callback Ctrl+S al primo render.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Registra il callback Ctrl+S
            dotNetRef = DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("registraCtrlS", dotNetRef); }
            catch { /* Ignora se JS non ancora pronto */ }
        }

        if (changesetEditorNeedsUpdate && !changesetEditorFocused)
        {
            changesetEditorNeedsUpdate = false;
            try
            {
                await JS.InvokeVoidAsync("changesetEditorHelper.setContent",
                    changesetEditorRef,
                    AttivitaCorrente.ChangesetCoinvolti ?? "");
            }
            catch { /* Ignora errori JS (es: elemento non ancora presente) */ }
        }

        if (noteEditorNeedsUpdate && !noteEditorFocused)
        {
            noteEditorNeedsUpdate = false;
            try
            {
                await JS.InvokeVoidAsync("noteEditorHelper.setContent",
                    noteEditorRef,
                    AttivitaCorrente.Note ?? "");
            }
            catch { /* Ignora errori JS */ }
        }
    }

    /// <summary>
    /// Inizializzazione del componente.
    /// Carica l'utente corrente, i dati di lookup e imposta i filtri alla data odierna.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Carica utente corrente
            var utente = await UserService.GetOrCreateCurrentUserAsync();
            _utenteCorrenteId = utente.Id;
            utenteConnesso = string.IsNullOrEmpty(utente.NomeCompleto)
                ? utente.WindowsUsername
                : $"{utente.NomeCompleto} ({utente.WindowsUsername})";

            // Carica dati lookup
            clienti = await ActivityService.GetClientiAsync();
            ambienti = await ActivityService.GetAmbientiAsync();
            anniDisponibili = await ActivityService.GetAnniDisponibiliAsync(isAdminMode);
            tipiAmbientiRilascio = await AmbientiRilascioService.GetTipiAsync();
            versioniRilascio = await AmbientiRilascioService.GetVersioniAsync();

            // Assicura che i tipi base esistano e carica la lista
            await TipiAttivitaService.EnsureTipiBaseAsync();
            tipiAttivitaLista = await TipiAttivitaService.GetTipiAsync();

            // Carica eventi imminenti per la barra di avviso
            eventiImminenti = await CalendarioService.GetEventiImminentiAsync();

            // Carica conteggio TODO
            todoCount = await TodoService.GetTodoCountAsync();
            
            // Carica conteggio Appunti
            appuntiCount = await AppuntiService.GetAppuntiCountAsync();

            // Carica conteggio segnalazioni non risolte
            segnalazioniCount = await SegnalazioneService.GetSegnalazioniNonRisolteCountAsync();

            // Imposta Anno e Mese al mese corrente; Giorno rimane "Tutti"
            // così si visualizzano subito le attività del mese in corso
            var oggi = DateTime.Today;
            FiltroAnno = oggi.Year;
            FiltroMese = oggi.Month;
            // FiltroGiorno = null (default) → mostra tutte le attività del mese

            // Carica attività del mese corrente
            await CaricaAttivita();

            // Inizializza il form con i valori di default corretti (Sviluppo auto-selezionato)
            // Va chiamato dopo il caricamento dei dati per avere clienteSviluppoId valorizzato
            NuovaAttivita();
        }
        catch (Exception ex)
        {
            MostraMessaggioConPopup($"Errore di connessione al database: {ex.Message}", true);
            isLoading = false;
        }
    }

    /// <summary>
    /// Chiamato da JavaScript quando l'utente preme Ctrl+S.
    /// </summary>
    [Microsoft.JSInterop.JSInvokable]
    public async Task SalvaViaShortcut()
    {
        await SalvaAttivita();
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Rilascia le risorse al termine della vita del componente.
    /// </summary>
    public void Dispose()
    {
        dotNetRef?.Dispose();
    }

    #endregion

    #region Caricamento Dati

    /// <summary>
    /// Carica le attività dal database applicando i filtri correnti.
    /// In modalità admin, carica le attività di tutti gli utenti.
    /// </summary>
    private async Task CaricaAttivita()
    {
        try
        {
            isLoading = true;
            Attivita = await ActivityService.GetActivitiesAsync(
                FiltroAnno, 
                FiltroMese, 
                FiltroGiorno, 
                string.IsNullOrWhiteSpace(TestoRicerca) ? null : TestoRicerca,
                isAdminMode);
            
            // Applica filtro "Solo TODO" se attivo
            if (filtroSoloTodo)
            {
                Attivita = Attivita.Where(a => ContieneTodo(a)).ToList();
            }
            
            anniDisponibili = await ActivityService.GetAnniDisponibiliAsync(isAdminMode);
        }
        catch (Exception ex)
        {
            MostraMessaggio($"Errore nel caricamento: {ex.Message}", true);
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Gestisce il cambio della modalità admin.
    /// Ricarica le attività per mostrare/nascondere quelle di altri utenti.
    /// </summary>
    private async Task OnAdminModeChanged()
    {
        await CaricaAttivita();
    }

    #endregion

    #region Gestione Selezione e Form

    /// <summary>
    /// Seleziona un'attività dalla griglia e popola il form con i suoi dati.
    /// Crea una copia per evitare modifiche dirette alla lista.
    /// </summary>
    private async Task SelezionaAttivita(WorkActivityDto attivita)
    {
        AttivitaCorrente = new WorkActivityDto
        {
            Id = attivita.Id,
            Data = attivita.Data,
            TipoAttivita = attivita.TipoAttivita ?? TipiAttivita.Lavoro,
            Descrizione = attivita.Descrizione,
            UrlTicket = attivita.UrlTicket,
            NumeroTicket = attivita.NumeroTicket,
            ClienteId = attivita.ClienteId,
