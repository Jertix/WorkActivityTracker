    /// <summary>
    /// Salva l'attività corrente (nuova o modifica).
    /// Esegue validazione prima del salvataggio.
    /// </summary>
    private async Task SalvaAttivita()
    {
        if (string.IsNullOrWhiteSpace(AttivitaCorrente.Descrizione))
        {
            MostraMessaggio("La descrizione è obbligatoria", true);
            return;
        }

        // Legge HTML dal contenteditable Note prima di salvare
        try
        {
            var htmlNote = await JS.InvokeAsync<string>("noteEditorHelper.getHtml", noteEditorRef);
            AttivitaCorrente.Note = string.IsNullOrWhiteSpace(htmlNote) ? null : htmlNote;
        }
        catch { /* Usa il valore già presente se la lettura JS fallisce */ }

        // Legge HTML dal contenteditable Changeset prima di salvare
        if (AttivitaCorrente.TipoAttivita == TipiAttivita.Lavoro)
        {
            try
            {
                var htmlChangeset = await JS.InvokeAsync<string>("changesetEditorHelper.getHtml", changesetEditorRef);
                AttivitaCorrente.ChangesetCoinvolti = string.IsNullOrWhiteSpace(htmlChangeset) ? null : htmlChangeset;
            }
            catch { /* Usa il valore già presente se la lettura JS fallisce */ }
        }

        try
        {
            isSaving = true;
            int savedId;

            if (IsModifica)
            {
                savedId = AttivitaCorrente.Id;
                await ActivityService.UpdateActivityAsync(AttivitaCorrente);
                MostraMessaggio("Attività aggiornata con successo!", false);
            }
            else
            {
                var saved = await ActivityService.AddActivityAsync(AttivitaCorrente);
                savedId = saved.Id;
                MostraMessaggio("Attività salvata con successo!", false);
            }

            // Registra l'orario dell'ultimo salvataggio (mostrato nella barra di stato)
            ultimoSalvataggio = DateTime.Now;

            // Salva lo storico versioni per Note e ChangesetCoinvolti (solo se non vuoti)
            try
            {
                if (!string.IsNullOrWhiteSpace(HtmlToPlainText(AttivitaCorrente.Note ?? "")))
                {
                    await EditorHistoryService.SalvaAsync(
                        savedId, _utenteCorrenteId, "Note",
                        AttivitaCorrente.Note, ultimoSalvataggio.Value);
                }

                if (AttivitaCorrente.TipoAttivita == TipiAttivita.Lavoro
                    && !string.IsNullOrWhiteSpace(HtmlToPlainText(AttivitaCorrente.ChangesetCoinvolti ?? "")))
                {
                    await EditorHistoryService.SalvaAsync(
                        savedId, _utenteCorrenteId, "ChangesetCoinvolti",
                        AttivitaCorrente.ChangesetCoinvolti, ultimoSalvataggio.Value);
                }
            }
            catch { /* Ignora errori sullo storico: non compromette il salvataggio principale */ }

            // Ricarica i datalist ambienti/versioni (potrebbero essere stati aggiunti nuovi valori)
            tipiAmbientiRilascio = await AmbientiRilascioService.GetTipiAsync();
            versioniRilascio = await AmbientiRilascioService.GetVersioniAsync();

            await CaricaAttivita();

            // Dopo il salvataggio, riseleziona l'attività appena salvata
            var attivitaSalvata = Attivita.FirstOrDefault(a => a.Id == savedId);
            if (attivitaSalvata != null)
            {
                await SelezionaAttivita(attivitaSalvata);
            }
            else
            {
                // Se non è visibile con i filtri correnti, resetta il form
                NuovaAttivita();
            }
        }
        catch (Exception ex)
        {
            MostraMessaggioConPopup($"Errore nel salvataggio: {ex.Message}", true);
        }
        finally
        {
            isSaving = false;
        }
    }

